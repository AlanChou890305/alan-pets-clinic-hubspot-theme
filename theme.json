              }
            },
            {
              "name": "accent_color",
              "label": "Accent Color",
              "type": "color",
              "default": {
                "color": "#F97316",
                "opacity": 100
              }
            },
            {
              "name": "text_color",
              "label": "Body Text Color",
              "type": "color",
              "default": {
                "color": "#111827",
                "opacity": 100
              }
            },
            {
              "name": "heading_color",
              "label": "Heading Color",
              "type": "color",
              "default": {
                "color": "#111827",
                "opacity": 100
              }
            }
          ]
        },
        {
          "name": "typography",
          "label": "Typography",
          "children": [
            {
              "name": "base_font",
