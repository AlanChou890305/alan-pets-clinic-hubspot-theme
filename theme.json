            {
              "name": "heading_font",
              "label": "Heading Font",
              "type": "font",
              "default": {
                "font": "Inter",
                "font_set": "GOOGLE",
                "size": 36,
                "size_unit": "px",
                "color": "#111827",
                "styles": {
                  "bold": true
                }
              }
            }
          ]
        },
        {
          "name": "spacing",
          "label": "Spacing",
          "children": [
            {
              "name": "max_page_width",
              "label": "Max Page Width (px)",
              "type": "number",
              "default": 1280
